{
    "interface_version": 2,
    "name": "MaaPTCGP",
    "description": "$description.file",
    "contact": "$contact.file",
    "license": "locales/LICENSE_SHORT.md",
    "welcome": "$welcome.file",
    "icon": "locales/MaaPTCGP-Tiny.png",
    "github": "https://github.com/vki1024gs/MaaPTCGP",
    "version": "v0.1.8",
    "controller": [
        {
            "name": "ADB",
            "label": "$controller.ADB.label",
            "description": "$controller.ADB.description",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "Default",
            "label": "$resource.Default.label",
            "description": "$resource.Default.description",
            "path": [
                "./resource"
            ],
            "controller": [
                "ADB"
            ]
        },
        {
            "name": "Dev",
            "label": "$resource.Dev.label",
            "description": "$resource.Dev.description",
            "path": [
                "../assets/resource"
            ],
            "controller": [
                "ADB"
            ]
        }
    ],
    "languages": {
        "zh_cn": "locales/interface/zh_cn.json",
        "zh_tw": "locales/interface/zh_tw.json",
        "en_us": "locales/interface/en_us.json"
    },
    "task": [],
    "group": [
        {
            "name": "DailyRoutine",
            "label": "$group.DailyRoutine.label",
            "description": "$group.DailyRoutine.description"
        },
        {
            "name": "utility",
            "label": "$group.utility.label",
            "description": "$group.utility.description"
        }
    ],
    "import": [
        "tasks/preset/BasicDailyRoutine.json",
        "tasks/Startup.json",
        "tasks/Mail.json",
        "tasks/Pack.json",
        "tasks/ShopDailyReward.json",
        "tasks/WonderPick.json",
        "tasks/Share.json",
        "tasks/Battle.json",
        "tasks/DailyMissions.json",
        "tasks/preset/Utility.json",
        "tasks/SwipeUp.json",
        "tasks/MissionRedDotCleaner.json"
    ]
}
